@page
@model BlueZoneNet.Adapter.ForParkingCars.WebUI.Pages.PurchaseTicketModel
@{
}
<main role="main" class="container">
    <div class="starter-template"><div>
        <h3>Ticket successfully purchased</h3>
        <hr>
        <h4>Your ticket code is <span>@Model.TicketCode</span></h4>
        <br>
        <p>Click on the button below to view ticket details</p>
        <form action="/GetTicket" method="post">
                <input type="hidden" name="ticketCode" value="@Model.TicketCode">
                <button type="submit" class="btn btn-dark">View Ticket</button>
        </form>
    </div>
</main>